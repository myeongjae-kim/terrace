{
  "name": "tanstack-start-opinionated",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpx husky",
    "dev": "vite dev --port 3000",
    "api:sync": "openapi-typescript http://localhost:3000/api/swagger -o ./src/lib/api/schema.d.ts && biome format --write ./src/lib/api/schema.d.ts",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check --fix",
    "find-deadcode": "bash scripts/find-deadcode.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "@fontsource/bad-script": "^5.2.8",
    "@fontsource/inconsolata": "^5.2.8",
    "@fontsource/noto-serif-kr": "^5.2.9",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.28",
    "inversify-typesafe-spring-like": "^0.5.5",
    "lucide-react": "^0.545.0",
    "marked": "^18.0.5",
    "marked-gfm-heading-id": "^4.1.4",
    "marked-highlight": "^2.2.4",
    "marked-mangle": "^1.1.13",
    "material-icons": "^1.13.14",
    "nitro": "npm:nitro-nightly@latest",
    "node-html-parser": "^9.0.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "pg": "^8.16.3",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "1.0.0-rc.4",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
